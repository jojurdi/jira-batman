# URL de tu Jira Cloud (sin slash final).
JIRA_BASE_URL=https://sibamex.atlassian.net

# OAuth 2.0 (3LO) — opcional. Si lo configuras, aparece el botón
# "Iniciar sesión con Atlassian" en la app.
# Crea la app en https://developer.atlassian.com/console/myapps/
JIRA_OAUTH_CLIENT_ID=
JIRA_OAUTH_CLIENT_SECRET=
# Local:
JIRA_OAUTH_REDIRECT_URI=http://localhost:8080/oauth/callback.php
# Prod (ejemplo): JIRA_OAUTH_REDIRECT_URI=https://tu-dominio.com/jira-batman/oauth/callback

# Prefijo de URL de la app. Si la app vive en la raíz del dominio, deja '/'.
# Si está en subdirectorio (ej. /jira-batman/), pon ese prefijo (con slash final).
APP_BASE_URL=/

# Zona horaria y horas por día (ambos opcionales).
TIMEZONE=America/Mexico_City
HOURS_PER_DAY=8

# SOLO para uso personal en una máquina con un único usuario (desarrollo local).
# Si está en true, JIRA_EMAIL y JIRA_API_TOKEN del .env se usan como fallback
# cuando no hay sesión OAuth ni cookies. En servidores con varios usuarios
# DEBE quedarse en false (o sin definir): de lo contrario cualquier visitante
# entraría como el dueño de esas credenciales.
ALLOW_ENV_FALLBACK=false
# JIRA_EMAIL=tu@correo.com
# JIRA_API_TOKEN=...
